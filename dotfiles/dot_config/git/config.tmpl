# Git configuration
# Managed by chezmoi

[user]
    name = {{ .name }}
    email = {{ .email }}

[pull]
    rebase = true

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false
    side-by-side = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[init]
    defaultBranch = main
