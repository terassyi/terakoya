// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-'": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-'": "editor::ToggleFocus",
      "ctrl-j": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Dock",
    "bindings": {}
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "n": "project_panel::NewFile",
      "d": "project_panel::NewDirectory",
      "space o": "project_panel::Open",
      "space v": "project_panel::OpenSplitVertical",
      "space h": "project_panel::OpenSplitHorizontal",
      "space b": "workspace::ToggleLeftDock",
      "space e": "editor::ToggleFocus"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space w": "workspace::Save",
      "space q": "workspace::CloseAllItemsAndPanes",
      "space b": "workspace::ToggleLeftDock",
      "space e": "project_panel::ToggleFocus",
      "space /": "editor::ToggleComments",
      // --- Navigation ---
      "g k": "editor::GoToDefinition",
      "g j": "editor::GoToTypeDefinition",
      "g i": "editor::GoToImplementation",
      "g f": "editor::FindAllReferences",
      "g +": "pane::GoBack",
      "g -": "pane::GoForward",
      // --- Refactoring & Actions ---
      "g r": "editor::Rename",
      "space a": "editor::ToggleCodeActions",
      "space =": "editor::Format",
      // --- Information & Search ---
      "K": "editor::Hover",
      "space s": "outline::Toggle",
      "space shift-s": "project_symbols::Toggle",
      "space h": "editor::ShowSignatureHelp",
      "space t": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space /": "editor::ToggleComments"
    }
  }
]
